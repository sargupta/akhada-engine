# Local-only V0. Cloud wiring lands V1.

# === Models (V0 uses local stubs; V1 wires real Vertex) ===
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_API_KEY=                     # Gemini API key for local dev
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro

# === GCP (V1+) ===
GCP_PROJECT=                        # leave blank for V0
GCP_REGION=asia-south1

# === Sarvam (22-language; V1+) ===
SARVAM_API_KEY=

# === Anthropic (gov-tier Opus synthesis via LiteLLM; V2+) ===
ANTHROPIC_API_KEY=

# === Telemetry ===
OTEL_EXPORTER_OTLP_ENDPOINT=        # blank → log spans only
OTEL_SERVICE_NAME=akhada-orchestrator

# === API ===
AKHADA_API_HOST=127.0.0.1
AKHADA_API_PORT=8080
AKHADA_LOG_LEVEL=INFO

# === Studio ===
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8080
